# ==> /home/realdhiru/nix/.gitignore <==

# =========================================================
# SECRETS (PRESERVE DIRECTORY, DROP CONTENTS)
# =========================================================
dotfiles/secrets/*
!dotfiles/secrets/.gitkeep

# =========================================================
# NIX BUILD ARTIFACTS
# =========================================================
result
result-*
.direnv/

# =========================================================
# PYTHON DAEMONS & FETCHERS
# =========================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# =========================================================
# IPC PIPES, LOGS, & RUNTIME STATE
# =========================================================
*.log
*.tmp
*.fifo
*.pid
.cache/

# =========================================================
# AI CONTEXT PACKERS
# =========================================================
repomix-output.xml
repomix.txt
repomix.json

# =========================================================
# OS & EDITOR NOISE
# =========================================================
.DS_Store
.vscode/
.idea/
*~
*.swp
*.swo
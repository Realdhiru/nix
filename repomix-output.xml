                    if (window.navDuration > 0) {
                        if (targetTop < contentY) {
                            contentY = targetTop;
                        } else if (targetBottom > contentY + height) {
                            contentY = targetBottom - height;
                        }
                    } else {
                        positionViewAtIndex(currentIndex, GridView.Contain);

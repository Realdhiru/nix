        }
    }

    // -------------------------------------------------------------------------
    // BACKGROUND AMBIENCE (Enhanced with more/bigger orbs)
    // -------------------------------------------------------------------------
    Item {
        anchors.fill: parent
        opacity: introBase
        scale: 0.95 + (0.05 * introBase)
        
        Rectangle {

            else if (box === 3) approxY = root.s(340);
            weatherLoader.item.scrollToBox(approxY);
        } else if (root.currentTab === 2 && keybindLoader.item) {
            let approxY = box * root.s(56) + root.s(120);
            keybindLoader.item.scrollToBox(approxY);

bind = $mainMod SHIFT, S, movetoworkspace, special:magic
# bindd = $mainMod ALT, S, $d move to scratchpad (silent), movetoworkspacesilent, special

# Move/resize with mouse
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow


# =========================
# Media
# =========================

binddl = Shift, F3, $d pause media, exec, playerctl play-pause
binddl = Shift, F4, $d previous media, exec, playerctl previous
binddl = Shift, F5, $d next media, exec, playerctl next

# bindl = , XF86AudioNext, exec, playerctl next
# bindl = , XF86AudioPause, exec, playerctl play-pause
# bindl = , XF86AudioPlay, exec, playerctl play-pause
# bindl = , XF86AudioPrev, exec, playerctl previous


# =========================
# Audio & Brightness
# =========================

bindel = , XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindel = , XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = , XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = , XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

bindel = , XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 1%+
bindel = , XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 1%-


# =========================
# Focus
# =========================

bind = $mainMod SHIFT, F, exec, hyprctl dispatch pin
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d


# =========================
# Resize Active Window
# =========================

bindde = $mainMod SHIFT, Right, $d resize window right, resizeactive, 30 0
bindde = $mainMod SHIFT, Left, $d resize window left, resizeactive, -30 0
bindde = $mainMod SHIFT, Up, $d resize window up, resizeactive, 0 -30
bindde = $mainMod SHIFT, Down, $d resize window down, resizeactive, 0 30


# =========================
# Workspaces
# =========================

bindd = $mainMod CTRL, Right, $d change active workspace forwards, workspace, r+1
bindd = $mainMod CTRL, Left, $d change active workspace backwards, workspace, r-1
bindd = $mainMod CTRL, Down, $d navigate to nearest empty workspace, workspace, empty

# Switch workspaces
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move windows to workspaces
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Zoom In: Uses NF (Number of Fields) to always target the last value regardless of string changes
bindn = $mainMod, mouse_up, exec, hyprctl keyword cursor:zoom_factor $(hyprctl getoption cursor:zoom_factor | grep float | awk '{print $NF + 0.9}')

# Zoom Out: Instantly flattens back to 1.0 baseline layout
bindn = $mainMod, mouse_down, exec, hyprctl keyword cursor:zoom_factor 1.0

# bind = $mainMod, M, exit


# ======================================================
# Disabled / Hyde bindings
# ======================================================

# bindd = Control Alt, Delete, $d logout menu, exec, hyde-shell logoutlaunch
# bindd = Control_L,Alt_R, $d toggle waybar and reload config, exec, hyde-shell waybar --hide
# bindd = $mainMod Shift, E, $d file finder , exec, pkill -x rofi || $menu f
# bindd = $mainMod, TAB, $d window switcher , exec, pkill -x rofi || $menu w
# bindd = $mainMod, slash, $d keybindings hint, exec, pkill -x rofi || hyde-shell keybinds_hint c
# bindd = $mainMod, comma, $d emoji picker, exec, pkill -x rofi || hyde-shell emoji-picker
# bindd = $mainMod, period, $d glyph picker, exec, pkill -x rofi || hyde-shell glyph-picker
# bindd = $mainMod, V, $d clipboard, exec, pkill -x rofi || hyde-shell cliphist -c
# bindd = $mainMod Shift, V, $d clipboard manager, exec, pkill -x rofi || hyde-shell cliphist
# bindd = $mainMod Shift, A, $d select rofi launcher, exec, pkill -x rofi || hyde-shell rofiselect
# bindd = $mainMod ALT, G, $d game mode, exec, hyde-shell gamemode
# bindd = $mainMod SHIFT, G, $d game launcher, exec, hyde-shell gamelauncher
# bindd = $mainMod SHIFT, P, $d color picker, exec, hyprpicker -an
# binddl = , Print, $d print all monitors, exec, hyde-shell screenshot p
# bindd = $mainMod ALT, Right, $d next wallpaper, exec, hyde-shell wallpaper -Gn
# bindd = $mainMod ALT, Left, $d previous wallpaper, exec, hyde-shell wallpaper -Gp
# bindd = $mainMod SHIFT, W, $d wallpaper selector, exec, pkill -x rofi || hyde-shell wallpaper -SG
# bindd = $mainMod ALT, Up, $d next waybar layout, exec, hyde-shell wbarconfgen n
# bindd = $mainMod ALT, Down, $d previous waybar layout, exec, hyde-shell wbarconfgen p
# bindd = $mainMod SHIFT, R, $d wallbash mode selector, exec, pkill -x rofi || hyde-shell wallbashtoggle -m
# bindd = $mainMod SHIFT, T, $d theme selector, exec, pkill -x rofi || hyde-shell themeselect
# bindd = $mainMod SHIFT, Y, $d animation selector, exec, pkill -x rofi || hyde-shell animations --select
# bindd = $mainMod SHIFT, U, $d hyprlock selector, exec, pkill -x rofi || hyde-shell hyprlock --select

# SwayOSD

# bindl = , XF86MonBrightnessDown, exec, swayosd-client --brightness lower
# bindl = , XF86MonBrightnessUp, exec, swayosd-client --brightness raise

# bindl = , XF86AudioMute, exec, swayosd-client --output-volume mute-toggle
# bindl = , XF86AudioMicMute, exec, swayosd-client --input-volume mute-toggle

# bindel = , XF86AudioLowerVolume, exec, swayosd-client --output-volume lower

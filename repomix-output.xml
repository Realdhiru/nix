                        for (let key in data) {
                            if (root.hasOwnProperty(key) && key !== "colorsFile" && key !== "_lastJson") {
                                root[key] = data[key];
                            }
                        }
                        root._lastJson = txt;
                    } catch(e) {}
                }
            }
        }
    }

    Timer {
        id: colorPollTimer
        interval: 3000
        running: true
        repeat: true
        triggeredOnStart: true
        onTriggered: {
            colorReader.running = false;
            colorReader.running = true;
        }
    }
}

<file path="dotfiles/rofi/theme.rasi">
* {
    /* --- GLASS CONTROLS --- */
    bg-glass:            rgba(0, 0, 0, 0.45);      /* Darkened translucent base */
    bg-surface:          rgba(255, 255, 255, 0.03);/* Input bar sheen */
    bg-selected:         rgba(255, 255, 255, 0.08);/* Active item highlight */
    border-glass:        rgba(255, 255, 255, 0.12);/* Border rim reflection */
    
    fg-main:             #FFFFFF;
    fg-muted:            #B0B0B0;
    
    font:                "JetBrainsMono Nerd Font 11";
    background-color:    transparent;
    text-color:          @fg-main;
}

window {
    /* --- POSITION CONTROLS --- */
    anchor:              west;             
    location:            west;             
    x-offset:            8%;               /* Offset moves 5% out from the left screen boundary */
    y-offset:            0%;               

    /* --- DIMENSION CONTROLS --- */
    width:               400px;            /* Narrowed horizontal width */
    border:              0.2px;
    border-color:        @border-glass;
    border-radius:       16px;
    background-color:    @bg-glass;
    padding:             17px;
}

mainbox {
    spacing:             12px;
    children:            [ inputbar, listview ];
}

inputbar {
    spacing:             0px;              
    padding:             10px 16px;
    background-color:    @bg-surface;
    border:              1px;
    border-color:        @border-glass;
    border-radius:       10px;
    children:            [ entry ];        /* Prompt removed to prevent icon/spacing cuts */
}

entry {
    placeholder:         "Search applications...";
    placeholder-color:   @fg-muted;
}

listview {
    fixed-height:        false;
    dynamic:             true;
    lines:               6;                /* Shows exactly 6 applications */
    spacing:             6px;
    scrollbar:           false;
}

element {
    padding:             10px 14px;
    border-radius:       8px;
    spacing:             12px;
}

element normal normal, element alternate normal {
    background-color:    transparent;
    text-color:          @fg-main;
}

element selected normal {
    background-color:    @bg-selected;
    border:              1px;
    border-color:        rgba(255, 255, 255, 0.2);
    text-color:          @fg-main;
}

element-icon {
    size:                24px;
}

element-text {
    vertical-align:      0.5;
}
</file>


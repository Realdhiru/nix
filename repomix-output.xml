#!/usr/bin/env bash

# Strict execution environment
set -uo pipefail

# Source and initialize quickshell dynamic caching
source "$(dirname "${BASH_SOURCE[0]}")/caching.sh"
qs_ensure_cache "lock"

# Resolve the correct NixOS binary dynamically

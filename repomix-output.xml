                y: parent.height * 0.4 + Math.cos(parent.time * 1.2) * root.s(150)
                color: root.ambientBlue
                opacity: 0.05
                layer.enabled: true
                layer.effect: MultiEffect { blurEnabled: true; blurMax: 110; blur: 1.0 }
            }

            // Orb 3
            Rectangle {
